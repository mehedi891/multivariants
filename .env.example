# Example environment configuration for the MultiVariants website.
# Copy this file to `.env` and adjust values as needed.
# All values below are public CMS config (no secrets).

# CMS base URL (efoli-cms)
CMS_API_BASE_URL="https://efoli-cms.vercel.app"

# Site slug used when calling the public CMS APIs
CONTACT_SITE="multivariants"
DOCS_SITE="multivariants"
PARTNERS_SITE="multivariants"
CLIENTS_SITE="multivariants"
CHANGELOG_SITE="multivariants"
FAQ_SITE="multivariants"
BLOG_SITE="multivariants"

# Public CMS API paths
CONTACT_API_PATH="/api/public/contact"
SITE_CONFIG_API_PATH="/api/public/site-config"
BLOG_API_PATH="/api/public/posts"
DOCS_API_PATH="/api/public/docs"
PARTNERS_API_PATH="/api/public/partners"
CLIENTS_API_PATH="/api/public/clients"
CHANGELOG_API_PATH="/api/public/changelogs"
FAQ_API_PATH="/api/public/faqs"

# Blog API options
BLOG_API_LOG_ERRORS=true
BLOG_API_FORWARD_AUTH=false
BLOG_API_POSTS_URL="https://efoli-cms.vercel.app/api/public/posts"
BLOG_API_BASE_URL="https://efoli-cms.vercel.app"

# IndexNow — served key file lives at public/<INDEXNOW_KEY>.txt.
# On production deploys, postbuild submits the sitemap URLs to IndexNow.
INDEXNOW_KEY="a3f1c9e07b2d48f6a1c5e9d3b7028f4c"
INDEXNOW_HOST="multivariants.com"
